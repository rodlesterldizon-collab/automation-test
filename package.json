{
  "name": "automation-test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test:ui": "playwright test --ui",
    "test:cli": "playwright test --project=chromium",
    "test:api": "playwright test --project=api",
    "test:llm:groq": "promptfoo eval -c tests/api-llm/promptfooconfig.yaml -o report.html -j 1 --providers file://groqProvider.js",
    "test:llm:gemini": "promptfoo eval -c tests/api-llm/promptfooconfig.yaml -o report.html -j 1 --providers google:gemini-3.5-flash",
    "test:a11y": "node scripts/run-a11y.mjs",
    "test:perf": "source venv/bin/activate && bzt tests/all-perf/performance-test.yml -o execution.0.concurrency=${USERS:-20} -o modules.console.disable=true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@heyputer/puter.js": "^2.5.4",
    "@playwright/test": "1.59.1",
    "@types/node": "^24.0.0",
    "chalk": "^5.6.2",
    "playwright-lighthouse": "^4.0.0",
    "promptfoo": "^0.121.17"
  },
  "dependencies": {
    "groq-sdk": "^1.3.0"
  }
}
