                      &lt;a href=&quot;/ssologin?context=web&amp;amp;uri=https%3A%2F%2Fdequeuniversity.com%2Fdemo%2Fmars%2Fassets%2Fdemo-sites%2Fmars%2Fimages%2Ffavicon.ico&quot; class=&quot;btn white dropshadow sm&quot;&gt;
