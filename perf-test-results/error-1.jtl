                &lt;a  data-lang=&quot;es&quot; lang=&quot;es&quot; aria-label=&quot;es Espa&amp;ntilde;ol&quot; data-index=&quot;2&quot; data-value=&quot;es&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;es&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;Español&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
            &lt;/li&gt;
                    &lt;li  class=&quot;component_DropDownMenu_item&quot; aria-current=&quot;false&quot; role=&quot;menuitem&quot;&gt;
                &lt;a  data-lang=&quot;fr&quot; lang=&quot;fr&quot; aria-label=&quot;fr Fran&amp;ccedil;ais&quot; data-index=&quot;3&quot; data-value=&quot;fr&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;fr&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;Français&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
            &lt;/li&gt;
                    &lt;li  class=&quot;component_DropDownMenu_item&quot; aria-current=&quot;false&quot; role=&quot;menuitem&quot;&gt;
                &lt;a  data-lang=&quot;it&quot; lang=&quot;it&quot; aria-label=&quot;it Italiano&quot; data-index=&quot;4&quot; data-value=&quot;it&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;it&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;Italiano&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
            &lt;/li&gt;
                    &lt;li  class=&quot;component_DropDownMenu_item&quot; aria-current=&quot;false&quot; role=&quot;menuitem&quot;&gt;
                &lt;a  data-lang=&quot;ja&quot; lang=&quot;ja&quot; aria-label=&quot;ja 日本語&quot; data-index=&quot;5&quot; data-value=&quot;ja&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;ja&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;日本語&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
