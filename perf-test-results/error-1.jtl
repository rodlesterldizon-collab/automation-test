&lt;/div&gt;&lt;section id=&quot;content&quot; class=&quot;container&quot;&gt;&lt;div class=&quot;vertical-space&quot;&gt;&lt;/div&gt;&lt;!--isValid FINAL = true --&gt;&lt;div class=&quot;span7 left-first pull-left&quot; id=&quot;left-column&quot;&gt;&lt;div id=&quot;vap-section&quot;&gt;
&lt;h1 style=&quot;color:#eee;&quot;&gt;Destination Mars &lt;/h1&gt;
&lt;h2 style=&quot;color:#acbad0;&quot;&gt;A trip to Mars starts in your imagination. Are you bold enough, brave enough, &lt;strong&gt;foolish enough?&lt;/strong&gt; We are. You belong on Mars with fools like us. Most of us don&apos;t bite. Much.&lt;/h2&gt;&lt;/div&gt;
    &lt;!--isValid FINAL = true --&gt;&lt;div id=&quot;vap-section&quot;&gt;
&lt;!--isValid FINAL = true --&gt;&lt;div class=&quot;span2-5 vap-col left-first&quot; id=&quot;vap-plan&quot;&gt;&lt;!-- Template : re_module_c/simple-box --&gt;&lt;a href=&quot;mars2.html?a=be_bold&quot;&gt;
                &lt;h3&gt;Be Bold...&lt;/h3&gt;
                &lt;i class=&quot;icon-vap-plan&quot;&gt;&lt;/i&gt;
              &lt;/a&gt;&lt;p&gt;&lt;/p&gt;
              &lt;p&gt;Step out of your comfort zone, and into a rocket with enough fuel to blast a Manhattan-sized crater if it explodes. But it won&apos;t. Probably.&lt;br&gt;
&amp;nbsp; &lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;div class=&quot;&quot;&gt;
      &lt;ul&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=why_marscommuter&quot;&gt;
                &lt;i class=&quot;icon-plan-question&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Why MarsCommuter?&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=maps_and_guides&quot;&gt;
                &lt;i class=&quot;icon-plan-101&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Maps &amp;amp; Guides&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=ticket_info&quot;&gt;
                &lt;i class=&quot;icon-plan-pencil&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Ticket Info&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;!-- end # --&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;!-- end span2-5 vap-col left-first div--&gt;&lt;!--isValid FINAL = true --&gt;&lt;div class=&quot;span2-5 vap-col&quot; id=&quot;vap-book&quot;&gt;&lt;!-- Template : re_module_c/simple-box --&gt;&lt;a href=&quot;mars2.html?a=countdown&quot;&gt;
                &lt;h3&gt;Countdown...&lt;/h3&gt;
                &lt;i class=&quot;icon-vap-book&quot;&gt;&lt;/i&gt;
              &lt;/a&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;If you&apos;re serious about traveling to Mars - really serious - then &lt;a href=&quot;mars2.html?a=last_will&quot;&gt;prepare your last will and testament&lt;/a&gt;, and book a trip! &lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;div class=&quot;&quot;&gt;
      &lt;ul&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=book_tickets&quot;&gt;
                &lt;i class=&quot;icon-book-book&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Book Tickets&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=mars_passes&quot;&gt;
                &lt;i class=&quot;icon-book-find&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Mars Passes&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=seek_counseling&quot;&gt;
                &lt;i class=&quot;icon-book-reservation&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Seek counseling&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;!-- end # --&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;!-- end span2-5 vap-col div--&gt;&lt;!--isValid FINAL = true --&gt;&lt;div class=&quot;span2-5 vap-col&quot; id=&quot;vap-travel&quot;&gt;&lt;!-- Template : re_module_c/simple-box --&gt;&lt;a href=&quot;mars2.html?a=blast_off&quot;&gt;
                &lt;h3&gt;Blast Off!&lt;/h3&gt;
                &lt;i class=&quot;icon-vap-travel&quot;&gt;&lt;/i&gt;
              &lt;/a&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;Expect violent turbulence, bone-crushing g-forces, muscle atrophy, and certain death (hey, everyone&apos;s death is certain at some point, right?).&lt;br&gt;
&amp;nbsp; &lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;div class=&quot;&quot;&gt;
      &lt;ul&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=&quot;&gt;
                &lt;i class=&quot;icon-travel-app&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;MarsMobile app&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=fly_at_own_risk&quot;&gt;
                &lt;i class=&quot;icon-travel-exchange&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Fly at your own risk&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;!--isValid FINAL = true --&gt;&lt;li&gt;&lt;a class=&quot;link&quot; href=&quot;mars2.html?a=contact_us&quot;&gt;
                &lt;i class=&quot;icon-travel-phone&quot;&gt;&lt;/i&gt;
                &lt;span class=&quot;link-text&quot;&gt;Contact Us&lt;/span&gt;
              &lt;/a&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;!-- end # --&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;!-- end span2-5 vap-col div--&gt;&lt;/div&gt;&lt;!-- end div--&gt;
&lt;!--isValid FINAL = true --&gt;&lt;!--sSearchKey=home.promo.heading.p3 keyvalue = Special Offers err=false--&gt;&lt;div id=&quot;vertical-carousel&quot;&gt;
  
  &lt;div class=&quot;be-icon&quot;&gt;&lt;/div&gt;
  &lt;p class=&quot;carousel-title&quot;&gt;Special Offers&lt;/p&gt;
  
  &lt;div class=&quot;carousel&quot; style=&quot;visibility: visible; overflow: hidden; position: relative; z-index: 2; left: 0px; height: 420px;&quot;&gt;
     &lt;ul style=&quot;margin: 0px; padding: 0px; position: relative; list-style-type: none; z-index: 1; height: 1680px; top: -980px;&quot;&gt;
     
     &lt;!-- begin list --&gt;
     
                  &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=send_kids_to_mars&quot;&gt;
&lt;img src=&quot;/assets/demo-sites/mars/images/kids-space.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot; alt=&quot;Kids in space suits &quot;&gt;&lt;/a&gt;&lt;div class=&quot;deal-text&quot;&gt;
            &lt;h3&gt;
            &lt;a class=&quot;&quot; href=&quot;mars2.html?a=send_kids_to_mars&quot;&gt;Send Your Kids to Mars!&lt;/a&gt;&lt;/h3&gt;
            &lt;p&gt;Book a first class one-way ticket for 5 kids, at the cost of 4! No parent or guardian required. Don&apos;t worry, they&apos;ll be fine... &lt;a class=&quot;link-arrow&quot; href=&quot;mars2.html?a=send_kids_to_mars&quot;&gt;Send your kids to mars&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;
         &lt;/li&gt;
               
       &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=wookie&quot;&gt;
&lt;img src=&quot;/assets/demo-sites/mars/images/wookie.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot; alt=&quot;Wookie&quot;&gt;&lt;/a&gt;&lt;div class=&quot;deal-text&quot;&gt;
            &lt;h3&gt;
            &lt;a class=&quot;&quot; href=&quot;mars2.html?a=wookie&quot;&gt;Fly with a Wookie&lt;/a&gt;&lt;/h3&gt;
            &lt;p&gt;Fly with a wookie! Limited time offer! Or would you rather kiss a Wookie? We can arrange that. (Can someone move this walking carpet out of my way?) &lt;a class=&quot;link-arrow&quot; href=&quot;mars2.html?a=wookie&quot;&gt;Fly with a Wookie!&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;
         &lt;/li&gt;
         
         &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=stay_connected&quot;&gt;
&lt;img src=&quot;/assets/demo-sites/mars/images/global-free-days.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot; alt=&quot;Martian sunrise.&quot;&gt;&lt;/a&gt;&lt;div class=&quot;deal-text&quot;&gt;
            &lt;h3&gt;
            &lt;a class=&quot;&quot; href=&quot;mars2.html?a=stay_connected&quot;&gt;Get Radio on Uranus&lt;/a&gt;&lt;/h3&gt;
            &lt;p&gt;All of our packages come with radio connectivity to the far reaches of the solar system. Yup, you too can get Justin Bieber on Uranus. &lt;a href=&quot;mars2.html?a=stay_connected&quot;&gt;Find out about radio connectivity today.&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;
         &lt;/li&gt;
         
         &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=free_year&quot;&gt;
&lt;img src=&quot;/assets/demo-sites/mars/images/mars-sunrise.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot; alt=&quot;Beautiful baboon, blowing bubbles, biking backward&quot;&gt;&lt;/a&gt;&lt;div class=&quot;deal-text&quot;&gt;
            &lt;h3&gt;
            &lt;a class=&quot;&quot; href=&quot;mars2.html?a=free_year&quot;&gt;Free Year on Mars&lt;/a&gt;&lt;/h3&gt;
            &lt;p&gt;Book ten years on Mars and get an extra year for free! Eleven years on Mars! Yay! Oxygen and water not included. &lt;a href=&quot;mars2.html?a=free_year&quot;&gt;Book a free year on Mars&lt;/a&gt;.&lt;/p&gt;&lt;/div&gt;
         &lt;/li&gt;
         
         &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=crater_adventure&quot;&gt;
&lt;img src=&quot;/assets/demo-sites/mars/images/mars-spaceman.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot;&gt;&lt;/a&gt;&lt;div class=&quot;deal-text&quot;&gt;
            &lt;h3&gt;
            &lt;a class=&quot;&quot; href=&quot;mars2.html?a=crater_adventure&quot;&gt;10% off Crater Adventure&lt;/a&gt;&lt;/h3&gt;
            &lt;p&gt;Book select MarStar Crater tickets and enjoy 10% off the Crater Adventures Pass. Safety not guaranteed. &lt;a href=&quot;mars2.html?a=crater_adventure&quot;&gt;Book your MarStar Crater Package today to save!&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;
         &lt;/li&gt;
         
         &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=ice_cream&quot;&gt;
&lt;img src=&quot;/assets/demo-sites/mars/images/space-station.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot; alt=&quot;icecream.jpg &quot;&gt;&lt;/a&gt;&lt;div class=&quot;deal-text&quot;&gt;
            &lt;h3&gt;
            &lt;a class=&quot;&quot; href=&quot;mars2.html?a=ice_cream&quot;&gt;Free Astronaut Ice Cream&lt;/a&gt;&lt;/h3&gt;
            &lt;p&gt;Spend an extra 3 months in orbit around Mars in our newly-remodelled MarsPod and get a free package of freeze-wrapped dehydrated astronaut ice cream. &lt;a class=&quot;link-arrow&quot; href=&quot;mars2.html?a=ice_cream&quot;&gt;Get your free dehydrated ice cream!&lt;/a&gt;
&lt;/p&gt;&lt;/div&gt;
         &lt;/li&gt;
         
    &lt;li style=&quot;overflow: hidden; float: none; width: 526px; height: 120px;&quot;&gt;&lt;a href=&quot;mars2.html?a=low_price_guarantee&quot;&gt;&lt;img src=&quot;/assets/demo-sites/mars/images/mars-lander.jpg&quot; class=&quot;&quot; width=&quot;210&quot; height=&quot;120&quot; alt=&quot;Mars Lander&quot;&gt;&lt;/a&gt;
         &lt;div class=&quot;deal-text&quot;&gt;
           &lt;h3&gt; &lt;a class=&quot;link&quot; href=&quot;mars2.html?a=low_price_guarantee&quot;&gt;Lowest Price Guarantee&lt;/a&gt;&lt;/h3&gt;
           &lt;p&gt;If within 24 hours of booking with us you find a lower online published price for the exact same rocket ticket to Mars, we buy you a milkshake, then send you on a one-way trip to the Sun. &lt;a href=&quot;mars2.html?a=low_price_guarantee&quot;&gt;Find out how this deal works.&lt;/a&gt; &lt;/p&gt;
           &lt;p&gt;&amp;nbsp;&lt;/p&gt;
           &lt;p&gt;&lt;/p&gt;
         &lt;/div&gt;
       &lt;/li&gt;
         
         
         &lt;!-- repeat liest --&gt;
         
