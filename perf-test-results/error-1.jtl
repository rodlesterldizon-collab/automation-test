                &lt;a  data-lang=&quot;de&quot; lang=&quot;de&quot; aria-label=&quot;de Deutsch&quot; data-index=&quot;0&quot; data-value=&quot;de&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;de&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;Deutsch&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
            &lt;/li&gt;
                    &lt;li  class=&quot;component_DropDownMenu_item&quot; aria-current=&quot;true&quot; role=&quot;menuitem&quot;&gt;
                &lt;a  data-lang=&quot;en&quot; lang=&quot;en&quot; aria-label=&quot;en English&quot; data-index=&quot;1&quot; data-value=&quot;en&quot; data-selected=&quot;true&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;en&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;English&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; &gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
            &lt;/li&gt;
