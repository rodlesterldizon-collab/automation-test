                &lt;a  data-lang=&quot;pt&quot; lang=&quot;pt&quot; aria-label=&quot;pt Portugu&amp;ecirc;s&quot; data-index=&quot;7&quot; data-value=&quot;pt&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;pt&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;Português&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
            &lt;/li&gt;
                    &lt;li  class=&quot;component_DropDownMenu_item&quot; aria-current=&quot;false&quot; role=&quot;menuitem&quot;&gt;
                &lt;a  data-lang=&quot;zh&quot; lang=&quot;zh&quot; aria-label=&quot;zh 中国的&quot; data-index=&quot;8&quot; data-value=&quot;zh&quot; data-selected=&quot;false&quot; onclick=&quot;UI_LanguageSwitcher_ChangeLanguage(this); return false;&quot; href=&quot;missing#&quot;&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;zh&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;中国的&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_selectedIndicator&quot;&gt;&lt;span class=&quot;fas fa-check&quot; hidden=&quot;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;
