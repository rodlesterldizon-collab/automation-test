&lt;script&gt;
    const AMPLITUDE_API_KEY_DQU = &apos;b01595dbae7acd9116c8ca4cf425855b&apos;;
    const AMPLITUDE_ENTERPRISE_ID = &quot;Deque University&quot;;
    const AMPLITUDE_CLIENT_ID = &quot;Deque University&quot;;

    /*
    ,
        &quot;enterpriseIdList&quot;: 
                &quot;organization&quot;: 
        &quot;organization_name&quot;: ,

        */

 
    const AMPLITUDE_USER = {
        &quot;id&quot;:                &quot;&quot;,
        &quot;enterpriseId&quot;:     &quot;&quot;    };
    const AMPLITUDE_LANG = &quot;en&quot;;

    function getPageCategory(path) {
        if (path === &apos;/&apos;)                                                          return &apos;home&apos;;
        if (path.indexOf(&apos;/rules/axe/&apos;) !== -1 || path === &apos;/rules/axe&apos;)         return &apos;rules-axe&apos;;
        if (path.indexOf(&apos;/class/&apos;) !== -1      || path === &apos;/class&apos;)             return &apos;class&apos;;
        if (path.indexOf(&apos;/rules/&apos;) !== -1      || path === &apos;/rules&apos;)             return &apos;rules&apos;;
        if (path.indexOf(&apos;/dashboard/&apos;) !== -1  || path === &apos;/dashboard&apos;)         return &apos;dashboard&apos;;
        return &apos;other&apos;;
    }

    function dquAmplitude(userType, eventMsg) {
        DequeAnalytics.identify(PROJECT_NAME, AMPLITUDE_USER.id, {
            ...AMPLITUDE_USER,
        });
        if (userType.toLowerCase().trim() == &apos;user&apos;) {
            DequeAnalytics.track(PROJECT_NAME, &apos;Page Viewed&apos;, {
                page_path:     eventMsg,
                locale:        AMPLITUDE_LANG,
                page_category: getPageCategory(eventMsg)
            });
        }
    }

    document.addEventListener(&apos;DOMContentLoaded&apos;, function () {
        PROJECT_NAME = &apos;deque-university&apos;;
        DequeAnalytics.init(PROJECT_NAME, {
            apiKey: AMPLITUDE_API_KEY_DQU,
            defaultTracking: {
                pageViews: false,       // Tracked manually via dquAmplitude() below — would duplicate
                sessions: true,
                formInteractions: true,
                fileDownloads: true
            }
        });
        dquAmplitude(&apos;user&apos;, window.location.pathname);
    });
&lt;/script&gt;&lt;/body&gt;

