            &lt;div class=&quot;component_DropDownMenu_preContent&quot;&gt;
                &lt;span class=&quot;fas fa-globe language-globe&quot;&gt;&lt;/span&gt;&amp;nbsp;&amp;nbsp;            &lt;/div&gt;
            &lt;span class=&quot;component_DropDownMenu_content&quot;&gt;
                    &lt;button aria-haspopup=&quot;menu&quot; aria-expanded=&quot;false&quot; aria-controls=&quot;dqu-ui-component-1_itemList&quot; class=&quot;component_DropDownMenu_button&quot;&gt;&lt;span class=&quot;component_DropDownMenu_arrow fa fa-angle-down&quot;&gt;&lt;/span&gt;&lt;span class=&quot;component_DropDownMenu_itemLabel&quot;&gt;&lt;span class=&quot;component_LanguageSwitcher_langCode&quot;&gt;en&lt;/span&gt;&amp;nbsp;&lt;span class=&quot;component_LanguageSwitcher_langName&quot;&gt;English&lt;/span&gt;&lt;/span&gt;&lt;/button&gt;
    &lt;div id=&quot;dqu-ui-component-1_itemList&quot; class=&quot;component_DropDownMenu_popup&quot; hidden=&quot;&quot;&gt;
        &lt;div class=&quot;component_DropDownMenu_popupHeader&quot;&gt;
                    &lt;/div&gt;
