{
 "execution": [
  {
   "concurrency": 20,
   "ramp-up": "30s",
   "hold-for": "1m",
   "scenario": "api-load-test"
  }
 ],
 "scenarios": {
  "api-load-test": {
   "default-address": "https://reqres.in",
   "headers": {
    "x-api-key": "free_user_3FV2fJGmFELswbMj91CZsT6vXxA"
   },
   "requests": [
    {
     "url": "/api/users?page=2",
     "method": "GET",
     "assert": [
      {
       "contains": [
        200
       ],
       "subject": "http-code",
       "not": false
      }
     ]
    },
    {
     "url": "/api/users",
     "method": "POST",
     "headers": {
      "Content-Type": "application/json"
     },
     "body": "{\"name\": \"test_user\", \"job\": \"leader\"}",
     "assert": [
      {
       "contains": [
        201
       ],
       "subject": "http-code",
       "not": false
      }
     ]
    },
    {
     "url": "/api/users/2",
     "method": "PUT",
     "headers": {
      "Content-Type": "application/json"
     },
     "body": "{\"name\": \"morpheus\", \"job\": \"zion resident\"}",
     "assert": [
      {
       "contains": [
        200
       ],
       "subject": "http-code",
       "not": false
      }
     ]
    },
    {
     "url": "/api/users/2",
     "method": "DELETE",
     "assert": [
      {
       "contains": [
        204
       ],
       "subject": "http-code",
       "not": false
      }
     ]
    },
    {
     "url": "/api/unknown",
     "method": "GET",
     "assert": [
      {
       "contains": [
        200
       ],
       "subject": "http-code",
       "not": false
      }
     ]
    },
    {
     "url": "https://dequeuniversity.com/demo/mars/",
     "method": "GET",
     "assert": [
      {
       "contains": [
        404
       ],
       "subject": "http-code",
       "not": false
      }
     ]
    }
   ]
  }
 },
 "reporting": [
  {
   "module": "final-stats",
   "summary": true,
   "dump-csv": "stats.csv"
  },
  {
   "module": "passfail",
   "criteria": [
    "avg-rt > 500ms for 10s, continue as non-failing",
    "fail > 5% for 10s, continue as non-failing"
   ]
  }
 ],
 "modules": {
  "jmeter": {
   "version": "5.6.3"
  }
 }
}
